{{ 'post-carrieres.css' | asset_url | stylesheet_tag }}

<div class="container-post-carrieres">
  <h2 class="section-title">{{ section.settings.section_title }}</h2>
  <div class="post-carrieres__content">
    {%  liquid
      assign career_posts = metaobjects.career_posts.values
    %}
    {% for post in career_posts %}
      <div class="post-carrieres__item">
        <div class="post-heading">
          <h3 class="post-carrieres__title">{{ post.title | strip_html }}</h3>
          <p class="post-carrieres__excerpt">
            <span>
              Location: {% for loc in post.location.value %}
                {{ loc | strip_html }}
              {% endfor %}
            </span>
            <span>
              | type de poste: {% for type in post.job_type.value %}
                {{ type | strip_html }}
              {% endfor %}
            </span>
          </p>
        </div>
        <div class="post-body">
          <div class="post-description">{{ post.description | metafield_tag  }}</div>
          <div class="post-link">
            <a href="{{ post.indeed_url.value }}" class="button" target="_blank" rel="noopener">Voir l'offre</a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const items = document.querySelectorAll('.post-carrieres__item .post-heading');
    console.log(items);
    items.forEach(item => {
      item.addEventListener('click', function() {
        this.closest('.post-carrieres__item').classList.toggle('active');
      });
    });
  });
</script>

{% schema %}
  {
    "name": "Post Carrieres",
    "tag": "section",
    "class": "post-carrieres",
    "settings": [
      {
        "type": "text",
        "id": "section_title",
        "label": "Section title",
        "default": "Nos offres d'emploi"
      }
    ],
    "presets": [
      {
        "name": "Post Carrieres"
      }
    ]
  }
{% endschema %}